{
    "name": "squadra Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "squadra",
    "workspaceFolder": "/workspaces/squadra",
    // Create the in-repo `.venv` (uv sync) and assert gpgsign off on container create.
    // gpgsign is also baked into the image; re-asserting it here is belt-and-suspenders.
    // billet runs this after a cold `billet start`; VS Code runs it on container create.
    "postCreateCommand": "git config --global commit.gpgsign false && uv sync --frozen",
    // NO "features" block on purpose: billet brings this container up with raw
    // `docker compose` and never applies devcontainer features, so `gh` (formerly the
    // github-cli feature) is baked into the image instead. Authenticate with
    // `gh auth login` (device flow) — documented in docs/dev-container.md.
    "remoteUser": "dev",
    "customizations": {
        "vscode": {
            "settings": {
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports.ruff": "explicit"
                    }
                },
                "explorer.compactFolders": false,
                "python.defaultInterpreterPath": "/workspaces/squadra/.venv/bin/python",
                "python.languageServer": "Pylance",
                // Type-checking is enforced via `uv run pyright` (strict), not Pylance.
                "python.analysis.typeCheckingMode": "off",
                "python.testing.pytestArgs": [
                    "tests"
                ],
                "python.testing.pytestEnabled": true,
                "python.testing.unittestEnabled": false
            },
            "extensions": [
                "anthropic.claude-code",
                "charliermarsh.ruff",
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}
