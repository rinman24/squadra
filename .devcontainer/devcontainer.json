{
    "name": "squadra Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "squadra",
    "workspaceFolder": "/workspace",
    // Create the in-repo `.venv` (uv sync), assert gpgsign off, and apply the
    // `rinman24/dotfiles` chezmoi profile (tmux.conf + TPM, NeoVim, Claude Code) on
    // container create. gpgsign is also baked into the image; re-asserting it here is
    // belt-and-suspenders. billet runs this after a cold `billet start`; VS Code runs it
    // on container create. The chezmoi step is idempotent — `update --apply` refreshes an
    // existing checkout, `init --apply rinman24` bootstraps it on first run (resolves to
    // https://github.com/rinman24/dotfiles over HTTPS). chezmoi is baked into the image
    // (see ../Dockerfile).
    "postCreateCommand": "git config --global commit.gpgsign false && uv sync --frozen && export PATH=\"$HOME/.local/bin:$PATH\" && (chezmoi update --apply || chezmoi init --apply rinman24)",
    // NO "features" block on purpose: billet brings this container up with raw
    // `docker compose` and never applies devcontainer features, so `gh` (formerly the
    // github-cli feature) is baked into the image instead. Authenticate with
    // `gh auth login` (device flow) — documented in docs/dev-container.md.
    "remoteUser": "dev",
    "customizations": {
        "vscode": {
            "settings": {
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports.ruff": "explicit"
                    }
                },
                "explorer.compactFolders": false,
                "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
                "python.languageServer": "Pylance",
                // Type-checking is enforced via `uv run pyright` (strict), not Pylance.
                "python.analysis.typeCheckingMode": "off",
                "python.testing.pytestArgs": [
                    "tests"
                ],
                "python.testing.pytestEnabled": true,
                "python.testing.unittestEnabled": false
            },
            "extensions": [
                "anthropic.claude-code",
                "charliermarsh.ruff",
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}
